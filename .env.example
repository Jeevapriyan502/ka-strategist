# Supabase (from supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# Server-only — for /admin/blog (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional — run `npm run supabase:setup` to create tables automatically
# Get from: Supabase → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_DB_PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres

# Blog admin (set a strong password)
ADMIN_PASSWORD=your_secure_admin_password

# Contact phone (used for tel: links — not shown on site)
NEXT_PUBLIC_CONTACT_PHONE=8489180043

# Resend (from resend.com → API Keys)
RESEND_API_KEY=re_your_api_key
# Where contact form notifications are sent
CONTACT_EMAIL=info@kastrategist.com
# Optional — after domain verification in Resend
# RESEND_FROM_EMAIL=KA Strategist <hello@kastrategist.com>
